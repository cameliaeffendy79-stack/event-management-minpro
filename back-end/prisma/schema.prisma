generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  CUSTOMER
  ORGANIZER
}

enum TransactionStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model users {
  id       Int     @id @default(autoincrement())
  name     String? @db.VarChar(100)
  email    String  @unique @db.VarChar(100)
  password String

  role Role @default(CUSTOMER)

  // ✅ REFERRAL SYSTEM
  referral_code String? @unique @db.VarChar(20)

  referred_by_id Int?

  referred_by users? @relation("UserReferral", fields: [referred_by_id], references: [id])

  referrals users[] @relation("UserReferral")

  // ✅ USER POINTS
  points_balance Int? @default(0)

  profile_picture String?

  created_at DateTime? @default(now()) @db.Timestamp(6)

  // ✅ RELATIONS
  coupons      coupons[]
  events       events[]
  points       points[]
  reviews      reviews[]
  transactions transactions[]
}

model events {
  id            Int       @id @default(autoincrement())
  title         String?   @db.VarChar(255)
  description   String?
  start_date    DateTime? @db.Timestamp(6)
  end_date      DateTime? @db.Timestamp(6)
  category      String?   @db.VarChar(100)
  location      String?   @db.VarChar(100)
  organizer_id  Int?
  created_at    DateTime? @default(now()) @db.Timestamp(6)
  updated_at    DateTime? @default(now()) @db.Timestamp(6)
  venue_name    String?   @db.VarChar(255)
  venue_address String?
  latitude      Decimal?  @db.Decimal
  longitude     Decimal?  @db.Decimal

  users        users?         @relation(fields: [organizer_id], references: [id])
  reviews      reviews[]
  tickets      tickets[]
  transactions transactions[]
  vouchers     vouchers[]
}

model tickets {
  id       Int     @id @default(autoincrement())
  event_id Int?
  name     String? @db.VarChar(100)
  price    Int?
  quota    Int?
  sold     Int?    @default(0)

  events            events?             @relation(fields: [event_id], references: [id], onDelete: Cascade)
  transaction_items transaction_items[]
}

model transactions {
  id              Int               @id @default(autoincrement())
  user_id         Int?
  event_id        Int?
  status          TransactionStatus @default(PENDING) // ✅ ENUM
  total_price     Int?
  payment_proof   String?
  expired_at      DateTime?         @db.Timestamp(6)
  created_at      DateTime?         @default(now()) @db.Timestamp(6)
  original_price  Int?
  discount_amount Int?              @default(0)
  final_price     Int?
  coupon_id       Int?
  voucher_id      Int?
  updated_at      DateTime?         @default(now()) @db.Timestamp(6)

  transaction_items transaction_items[]
  coupons           coupons?            @relation(fields: [coupon_id], references: [id], map: "fk_coupon")
  vouchers          vouchers?           @relation(fields: [voucher_id], references: [id], map: "fk_voucher")
  events            events?             @relation(fields: [event_id], references: [id])
  users             users?              @relation(fields: [user_id], references: [id])
}

model transaction_items {
  id             Int  @id @default(autoincrement())
  transaction_id Int?
  ticket_id      Int?
  quantity       Int?
  price          Int?
  subtotal       Int?

  tickets      tickets?      @relation(fields: [ticket_id], references: [id])
  transactions transactions? @relation(fields: [transaction_id], references: [id], onDelete: Cascade)
}

model vouchers {
  id              Int       @id @default(autoincrement())
  event_id        Int?
  discount_amount Int?
  start_date      DateTime? @db.Timestamp(6)
  end_date        DateTime? @db.Timestamp(6)
  quota           Int?
  used_count      Int?      @default(0)

  transactions transactions[]
  events       events?        @relation(fields: [event_id], references: [id])
}

model coupons {
  id              Int       @id @default(autoincrement())
  user_id         Int?
  discount_amount Int?
  expired_at      DateTime? @db.Timestamp(6)
  is_used         Boolean?  @default(false)

  users        users?         @relation(fields: [user_id], references: [id])
  transactions transactions[]
}

model points {
  id         Int       @id @default(autoincrement())
  user_id    Int?
  amount     Int?
  expired_at DateTime? @db.Timestamp(6)
  is_used    Boolean?  @default(false)
  created_at DateTime? @default(now()) @db.Timestamp(6)

  users users? @relation(fields: [user_id], references: [id])
}

model reviews {
  id         Int       @id @default(autoincrement())
  user_id    Int?
  event_id   Int?
  rating     Int?
  comment    String?
  created_at DateTime? @default(now()) @db.Timestamp(6)

  events events? @relation(fields: [event_id], references: [id])
  users  users?  @relation(fields: [user_id], references: [id])
}
