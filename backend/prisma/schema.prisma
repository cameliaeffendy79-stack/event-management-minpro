generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model users {
  id              Int            @id @default(autoincrement())
  name            String?
  email           String         @unique
  password        String
  role            String
  referral_code   String?        @unique
  referred_by     String?
  points_balance  Int?           @default(0)
  profile_picture String?
  created_at      DateTime?      @default(now())

  coupons         coupons[]
  events          events[]
  points          points[]
  reviews         reviews[]
  transactions    transactions[]
}

model events {
  id            Int            @id @default(autoincrement())
  title         String?
  description   String?
  start_date    DateTime?
  end_date      DateTime?
  category      String?
  location      String?
  organizer_id  Int?
  created_at    DateTime?      @default(now())
  updated_at    DateTime?      @updatedAt
  venue_name    String?
  venue_address String?
  latitude      Decimal?
  longitude     Decimal?

  users         users?         @relation(fields: [organizer_id], references: [id])
  reviews       reviews[]
  tickets       tickets[]
  transactions  transactions[]
  vouchers      vouchers[]
}

model tickets {
  id                Int                 @id @default(autoincrement())
  event_id          Int?
  name              String?
  price             Int?
  quota             Int?
  sold              Int?                @default(0)

  events            events?             @relation(fields: [event_id], references: [id])
  transaction_items transaction_items[]
}

model transactions {
  id                Int                 @id @default(autoincrement())
  user_id           Int?
  event_id          Int?
  status            String?
  total_price       Int?
  payment_proof     String?
  expired_at        DateTime?
  created_at        DateTime?           @default(now())
  original_price    Int?
  discount_amount   Int?                @default(0)
  final_price       Int?
  coupon_id         Int?
  voucher_id        Int?
  updated_at        DateTime?           @updatedAt

  users             users?              @relation(fields: [user_id], references: [id])
  events            events?             @relation(fields: [event_id], references: [id])
  coupons           coupons?            @relation(fields: [coupon_id], references: [id])
  vouchers          vouchers?           @relation(fields: [voucher_id], references: [id])
  transaction_items transaction_items[]
}

model transaction_items {
  id             Int           @id @default(autoincrement())
  transaction_id Int?
  ticket_id      Int?
  quantity       Int?
  price          Int?
  subtotal       Int?

  transactions   transactions? @relation(fields: [transaction_id], references: [id])
  tickets        tickets?      @relation(fields: [ticket_id], references: [id])
}

model coupons {
  id              Int            @id @default(autoincrement())
  user_id         Int?
  discount_amount Int?
  expired_at      DateTime?
  is_used         Boolean?       @default(false)

  users           users?         @relation(fields: [user_id], references: [id])
  transactions    transactions[]
}

model points {
  id         Int       @id @default(autoincrement())
  user_id    Int?
  amount     Int?
  expired_at DateTime?
  is_used    Boolean?  @default(false)
  created_at DateTime? @default(now())

  users      users?    @relation(fields: [user_id], references: [id])
}

model reviews {
  id         Int       @id @default(autoincrement())
  user_id    Int?
  event_id   Int?
  rating     Int?
  comment    String?
  created_at DateTime? @default(now())

  users      users?    @relation(fields: [user_id], references: [id])
  events     events?   @relation(fields: [event_id], references: [id])
}

model vouchers {
  id              Int            @id @default(autoincrement())
  event_id        Int?
  discount_amount Int?
  start_date      DateTime?
  end_date        DateTime?
  quota           Int?
  used_count      Int?           @default(0)

  events          events?        @relation(fields: [event_id], references: [id])
  transactions    transactions[]
}